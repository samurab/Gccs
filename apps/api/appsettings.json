{
  "Authentication": {
    "Authority": "",
    "Audience": ""
  },
  "Cors": {
    "AllowedOrigins": [
      "http://localhost:3000"
    ]
  },
  "Security": {
    "RateLimiting": {
      "PermitLimit": 120,
      "WindowMinutes": 1
    }
  },
  "SamGov": {
    "BaseUrl": "https://api.sam.gov",
    "TimeoutSeconds": 10,
    "MaxRetries": 2,
    "RateLimitPerMinute": 60
  },
  "LocalDependencies": {
    "Enabled": false
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*"
}
